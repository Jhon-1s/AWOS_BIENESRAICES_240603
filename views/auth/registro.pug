extends ../layout/index 

block content
    .py-1
        //- Título principal en verde
        h1.text-4xl.my-10.font-extrabold.text-center.text-green-500 Bienes
            span.font-normal.text-black Raíces
        h2.text-center.text-2xl.font-normal.text-black Por favor ingresa cuidadosamente tus datos

        if errores
            //- Contenedor principal flotante (Toast)
            div(class="alerta-temporal fixed top-5 right-5 z-50 w-full max-w-md bg-rose-950 border border-rose-900 rounded-lg shadow-2xl overflow-hidden transition-all duration-500 transform translate-x-0 opacity-100")
                div(class="p-4 flex items-start")
                    //- Ícono de error (Tachita roja)
                    div(class="flex-shrink-0")
                        svg(class="h-6 w-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                            path(stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z")
                    
                    //- Título y lista de errores
                    div(class="ml-3 w-0 flex-1 pt-0.5")
                        p(class="text-sm font-bold text-red-200") Hubo #{errores.length} error(es) en tu envío.
                        ul(class="mt-2 list-disc list-inside text-sm text-red-300 space-y-1")
                            each error in errores
                                li= error.msg
                
                //- Contenedor de la barra de progreso
                div(class="h-1 w-full bg-rose-900")
                    //- Esta es la barrita que se va a hacer pequeña
                    div(class="barra-progreso h-full bg-red-500 w-full ease-linear")
        .mt-8.mx-auto.max-w-xl
            .bg-white.py-8.px-4.shadow-2xl.rounded-2xl
                form.space-y-5(method="POST" action="/auth/registro" noValidate)
                    input(type="hidden" name="_csrf" value=csrfToken)
                    
                    div.px-5 
                        label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="nombreUsuario") nombre completo:
                        //- Clases de shadow y outline en verde
                        input#nombreUsuario(type="text" class="w-full border border-gray-300 px-3 py-2 rounded-xl placeholder-gray-400 hover:inset-shadow-sm focus:inset-shadow-xl focus:inset-shadow-green-300 focus:outline-none" placeholder="p.e.: Jonathan Isai Leal Cruz" name="nombreUsuario" value= usuario ? usuario.nombreUsuario: '')
                    
                    div.px-5 
                        label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="emailUsuario") correo electrónico:
                        input#emailUsuario(type="email" class="w-full border border-gray-300 px-3 py-2 rounded-xl placeholder-gray-400 hover:inset-shadow-sm focus:inset-shadow-xl focus:inset-shadow-green-300 focus:outline-none" placeholder="p.e.: correo@dominio.com" name="emailUsuario" value= usuario ? usuario.emailUsuario: '')
                    
                    //- Input Contraseña con funcionalidad del ojito
                    div.px-5
                        label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="passwordUsuario") Contraseña:
                        div.relative
                            input#passwordUsuario(type="password" class="w-full border border-gray-300 px-3 py-2 pr-10 rounded-xl placeholder-gray-400 hover:border-gray-400 focus:inset-shadow-md focus:inset-shadow-green-300/50 focus:outline-none" placeholder="Por los menos 8 carácteres" name="passwordUsuario")
                            button(type="button" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-green-500 transition-colors cursor-pointer" onclick="togglePassword('passwordUsuario', 'iconPasswordReg')")
                                svg#iconPasswordReg(xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                                    path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z")
                                    path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z")

                    //- Input Confirmación con funcionalidad del ojito
                    div.px-5
                        label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="confirmacionUsuario") Confirmación de Contraseña:
                        div.relative
                            input#confirmacionUsuario(type="password" class="w-full border border-gray-300 px-3 py-2 pr-10 rounded-xl placeholder-gray-400 hover:border-gray-400 focus:inset-shadow-md focus:inset-shadow-green-300/50 focus:outline-none" placeholder="Repite la contraseña anterior" name="confirmacionUsuario")
                            button(type="button" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-green-500 transition-colors cursor-pointer" onclick="togglePassword('confirmacionUsuario', 'iconConfirmReg')")
                                svg#iconConfirmReg(xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                                    path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z")
                                    path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z")
                    
                    //- Botón Submit principal
                    div.flex.justify-center.py-6
                        input(class="w-3/4 bg-gray-300 text-green-500 hover:bg-green-500 hover:text-white font-bold py-3 cursor-pointer rounded-4xl shadow-lg uppercase transition-all duration-200" type="submit" value="Registrar Usuario")

                    //- Enlaces (hover decoration en verde)
                    div.flex.items-center.justify-between.pt-3.px-5.mb-6
                        a(class="text-gray-500 text-sm hover:decoration-green-500 hover:underline transition decoration-2" href="/auth/login") ¿Ya tienes cuenta? Inicia Sesión
                        a(class="text-gray-500 text-sm hover:decoration-green-500 hover:underline transition decoration-2" href="/auth/recuperarPassword") ¿Olvidaste tu contraseña? Recupérala

                //- Separador Redes Sociales (fuera del form, pero dentro del card blanco)
                div.flex.items-center.px-5.mb-8.mt-4
                    div.flex-1.border-t.border-gray-300
                    span.px-3.text-gray-500.text-sm o con tu correo
                    div.flex-1.border-t.border-gray-300

                //- Botones de Redes Sociales
                div.px-5.space-y-4.mb-4
                    a(href="/auth/google" class="w-full flex items-center justify-center gap-3 bg-white border border-gray-300 text-gray-700 font-bold py-3 rounded-xl hover:bg-gray-50 transition-colors shadow-sm")
                        svg(class="w-5 h-5" viewBox="0 0 24 24")
                            path(d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4")
                            path(d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853")
                            path(d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05")
                            path(d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335")
                        | Continuar con Google

                    a(href="/auth/x" class="w-full flex items-center justify-center gap-3 bg-black text-white font-bold py-3 rounded-xl hover:bg-gray-800 transition-colors shadow-sm")
                        svg(class="w-5 h-5 fill-current" viewBox="0 0 24 24")
                            path(d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 22.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z")
                        | Continuar con X

    //- Script para el ojito (fuera del card blanco, pero dentro del layout)
    script.
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />';
            } else {
                input.type = 'password';
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />';
            }
        }