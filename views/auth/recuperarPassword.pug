
extends ../layout/index 

block content
   .py-10
        h1.text-4xl.my-10.font-extrabold.text-center.text-green-400 Bienes
            span.font-normal.text-black Raíces
        h2.text-center.text-2xl.font-normal.text-black Te enviaremos un email con la liga de restauración de contraseña

        if errores
            //- Contenedor principal flotante (Toast)
            div(class="alerta-temporal fixed top-5 right-5 z-50 w-full max-w-md bg-rose-950 border border-rose-900 rounded-lg shadow-2xl overflow-hidden transition-all duration-500 transform translate-x-0 opacity-100")
                div(class="p-4 flex items-start")
                    //- Ícono de error (Tachita roja)
                    div(class="flex-shrink-0")
                        svg(class="h-6 w-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                            path(stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z")
                    
                    //- Título y lista de errores
                    div(class="ml-3 w-0 flex-1 pt-0.5")
                        p(class="text-sm font-bold text-red-200") Hubo #{errores.length} error(es) en tu envío.
                        ul(class="mt-2 list-disc list-inside text-sm text-red-300 space-y-1")
                            each error in errores
                                li= error.msg
                
                //- Contenedor de la barra de progreso
                div(class="h-1 w-full bg-rose-900")
                    //- Esta es la barrita que se va a hacer pequeña
                    div(class="barra-progreso h-full bg-red-500 w-full ease-linear")
            //- Contenedor principal flotante (Toast)
            div(class="alerta-temporal fixed top-5 right-5 z-50 w-full max-w-md bg-rose-950 border border-rose-900 rounded-lg shadow-2xl overflow-hidden transition-all duration-500 transform translate-x-0 opacity-100")
                div(class="p-4 flex items-start")
                    //- Ícono de error (Tachita roja)
                    div(class="flex-shrink-0")
                        svg(class="h-6 w-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                            path(stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z")
                    
                    //- Título y lista de errores
                    div(class="ml-3 w-0 flex-1 pt-0.5")
                        p(class="text-sm font-bold text-red-200") Hubo #{errores.length} error(es) en tu envío.
                        ul(class="mt-2 list-disc list-inside text-sm text-red-300 space-y-1")
                            each error in errores
                                li= error.msg
                
                //- Contenedor de la barra de progreso
                div(class="h-1 w-full bg-rose-900")
                    //- Esta es la barrita que se va a hacer pequeña
                    div(class="barra-progreso h-full bg-red-500 w-full ease-linear") 
            .max-w-md.mx-auto.my-10 
                each error in errores 
                    p.bg-red-600.text-white.uppercase.text-xs.text-center.p-2.mb-1.font-bold= error.msg

        .mt-8.mx-auto.max-w-xl
            .bg-white.py-8.px-4.shadow-2xl.rounded-2xl
                form.space-y-5(method="POST" action="/auth/recuperarPassword" noValidate)
                        input(type="hidden" name="_csrf" value=csrfToken)
                
                        div.px-5 
                            label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="emailUsuario") correo electrónico:
                            input#emailUsuario(type="email" class="hover:inset-shadow-sm focus:inset-shadow-xl focus:inset-shadow-green-300 focus:outline-none" placeholder="p.e.: correo@dominio.com" name="emailUsuario" value= usuario ? usuario.emailUsuario: '').w-full.hover.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400
                        
                        div.flex.justify-center.py-6
                            input(class="w-3/4 bg-gray-300 text-green-400 hover:bg-green-400 hover:text-white font-bold py-3 cursor-pointer rounded-4xl shadow-lg uppercase transition-all.duration-200" type="submit" value="Enviar Correo de Restauración")

                        div.flex.items-center.justify-between.pt-3
                            a(class="text-gray-500 text-sm hover:decoration-green-400 hover:underline transition decoration-2" href="/auth/login") ¿Ya tienes cuenta? Inicia Sesión
                            a(class="text-gray-500 text-sm hover:decoration-green-400 hover:underline transition decoration-2" href="/auth/registro") ¿No tienes cuenta? Registrate

                             script.
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />';
            } else {
                input.type = 'password';
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />';
            }
        }