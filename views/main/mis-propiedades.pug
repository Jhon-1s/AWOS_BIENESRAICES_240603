extends ../layout/index

block content
    div.py-10
        //- Título principal de la sección
        h1.text-4xl.my-10.font-extrabold.text-center.text-green-400 Bienes
            span.font-normal.text-black Raíces
        h2.text-center.text-3xl.font-extrabold.text-gray-800= pagina

        //- Barra de acciones (Botón de Publicar)
        div.max-w-6xl.mx-auto.flex.justify-end.my-8.px-4
            a(href="/propiedades/crear" class="inline-block px-8 py-3 bg-black hover:bg-green-500 text-white text-sm font-bold text-center uppercase rounded-full transition-all duration-300 shadow-lg hover:shadow-green-500/40 transform hover:-translate-y-1") 
                | + Publicar Propiedad

        //- Contenedor principal
        div.bg-white.shadow-2xl.rounded-3xl.mx-auto.max-w-6xl.p-8.border.border-gray-100
            
            //- Aquí evaluaremos si el usuario tiene propiedades en la BD
            if propiedades && propiedades.length > 0
                //- Grid responsivo (1 columna en celular, 2 en tablet, 3 en escritorio)
                div(class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8")
                    each propiedad in propiedades
                        //- Tarjeta de propiedad (Aquí pondremos el diseño de la casa más adelante)
                        div.border.rounded-2xl.overflow-hidden.shadow-sm
                            p.p-4.text-center Propiedad de prueba
            
            else
                div.text-center.py-20
                    //- Ícono de casa minimalista
                    svg(class="mx-auto h-20 w-20 text-gray-300 mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1")
                        path(stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6")
                    
                    h3.text-2xl.font-bold.text-gray-800 Aún no tienes propiedades
                    p.mt-3.text-base.text-gray-500.max-w-md.mx-auto Tu panel está vacío. Empieza creando tu primer anuncio en la plataforma para que miles de personas lo vean.
                    
                    //- Botón secundario en el centro
                    a(href="/propiedades/crear" class="mt-8 inline-block px-6 py-2 bg-green-50 hover:bg-green-100 text-green-700 font-bold rounded-lg transition-colors border border-green-200")
                        | Crear mi primer anuncio